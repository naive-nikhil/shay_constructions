---
---
<div class="xs-sidebar-group info-group">
	<div class="xs-overlay xs-bg-black"></div>
	<div class="xs-sidebar-widget">
		<div class="sidebar-widget-container">
			<div class="widget-heading">
				<a href="#" class="close-side-widget">
					<i class="far fa-times-circle"></i>
				</a>
			</div>
			<div class="sidebar-textwidget">
				<div class="sidebar-info-contents">
					<div class="content-inner">
						<div class="nav-logo">
							<a href="/"><img src="/assets/images/shay_logo_light.png" alt="Shay Construction"></a>
						</div>

						<nav class="shay-sidebar-nav" aria-label="Main menu">
							<ul>
								<li><a href="/">Home</a></li>
								<li><a href="/about/">About</a></li>
								<li><a href="/service/">Services</a></li>
								<li><a href="/projects/">Projects</a></li>
								<li><a href="/contact/">Contact</a></li>
							</ul>
						</nav>

						<p class="shay-sidebar-tagline">SHAY Construction: Premium engineering for a sustainable future.</p>

						<div class="contact-info">
							<h2>Get In Touch</h2>
							<ul class="list-style-one shay-sidebar-contact">
								<li>
									<i class="bi bi-telephone"></i>
									+91 8318666574 | +91 7905249296<br />
									<span class="shay-sidebar-contact-indent">+91 8808788886 | +91 7275014659</span>
								</li>
								<li>
									<i class="bi bi-envelope-open"></i>
									<a href="mailto:shayconstructionpvtltd@gmail.com">shayconstructionpvtltd@gmail.com</a>
								</li>
								<li>
									<i class="bi bi-geo-alt"></i>
									E-2/110 Sudhant Golf City,<br />
									<span class="shay-sidebar-contact-indent">Lucknow, Uttar Pradesh, 226030</span>
								</li>
							</ul>
						</div>

						<ul class="social-box shay-sidebar-social">
							<li>
								<a href="https://www.facebook.com/shayconstructionpvtltd/" target="_blank" rel="noopener noreferrer" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
							</li>
							<li>
								<a href="https://www.instagram.com/shay_construction1/" target="_blank" rel="noopener noreferrer" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
							</li>
						</ul>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<style is:global>
.shay-sidebar-nav {
	margin: 28px 0 24px;
	padding-bottom: 24px;
	border-bottom: 1px solid rgba(255, 255, 255, 0.12);
}

.shay-sidebar-nav ul {
	list-style: none;
	margin: 0;
	padding: 0;
}

.shay-sidebar-nav li {
	margin: 0 0 12px;
}

.shay-sidebar-nav a {
	display: inline-block;
	font-size: 15px;
	font-weight: 600;
	letter-spacing: 0.06em;
	text-transform: uppercase;
	color: rgba(255, 255, 255, 0.92);
	text-decoration: none;
	transition: color 0.2s ease, padding-left 0.2s ease;
}

.shay-sidebar-nav a:hover {
	color: #1c4274;
	padding-left: 6px;
}

.shay-sidebar-tagline {
	font-size: 14px;
	line-height: 1.65;
	color: rgba(255, 255, 255, 0.75);
	margin: 0 0 28px;
	padding-bottom: 24px;
	border-bottom: 1px solid rgba(255, 255, 255, 0.12);
}

/* Override global ul.list-style-one li span (#ff3c00 / 20px) — keep all contact lines uniform */
.xs-sidebar-widget ul.list-style-one.shay-sidebar-contact li,
.xs-sidebar-widget ul.list-style-one.shay-sidebar-contact li span {
	font-size: 14px !important;
	font-weight: 400 !important;
	line-height: 1.6 !important;
	color: rgba(255, 255, 255, 0.88) !important;
	margin: 0 !important;
}

.xs-sidebar-widget ul.list-style-one.shay-sidebar-contact li {
	padding-top: 12px;
}

.xs-sidebar-widget ul.list-style-one.shay-sidebar-contact li i {
	margin-right: 10px;
	color: rgba(255, 255, 255, 0.55);
	font-size: 15px;
	vertical-align: middle;
}

.shay-sidebar-contact a {
	font-size: 14px !important;
	font-weight: 400 !important;
	color: rgba(255, 255, 255, 0.88) !important;
	text-decoration: none;
}

.shay-sidebar-contact a:hover {
	color: #6fa8dc;
}

.shay-sidebar-contact-indent {
	display: block;
	padding-left: 0;
	margin-top: 6px;
	margin-left: 0;
}

.xs-sidebar-widget .contact-info h2 {
	font-size: 18px;
	font-weight: 600;
	letter-spacing: 0.04em;
	text-transform: uppercase;
	color: rgba(255, 255, 255, 0.95);
	margin-bottom: 8px;
}

.shay-sidebar-social {
	display: flex;
	flex-wrap: wrap;
	gap: 12px;
	margin-top: 24px !important;
	padding: 0 !important;
	list-style: none !important;
}

.shay-sidebar-social li {
	margin: 0 !important;
}

.shay-sidebar-social a {
	display: flex;
	align-items: center;
	justify-content: center;
	width: 42px;
	height: 42px;
	border: 1px solid rgba(255, 255, 255, 0.25);
	color: #fff;
	font-size: 16px;
	transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
}

.shay-sidebar-social a:hover {
	background: #1c4274;
	border-color: #1c4274;
	color: #fff;
}
</style>
