<script is:inline>
document.addEventListener('DOMContentLoaded', function () {
	var cards = document.querySelectorAll('.shay-team-card');
	var overlay = document.getElementById('shayOverlay');
	var closeBtn = document.getElementById('shayOverlayClose');
	if (!overlay || !cards.length) return;

	var oImg = document.getElementById('shayOverlayImg');
	var oName = document.getElementById('shayOverlayName');
	var oRole = document.getElementById('shayOverlayRole');
	var oDesc = document.getElementById('shayOverlayDesc');

	function openOverlay(card) {
		oImg.src = card.dataset.img;
		oImg.alt = card.dataset.name;
		oName.textContent = card.dataset.name;
		oRole.textContent = card.dataset.role;
		oDesc.textContent = card.dataset.desc;
		overlay.classList.add('active');
	}

	function closeOverlay() {
		overlay.classList.remove('active');
	}

	cards.forEach(function (card) {
		card.addEventListener('click', function () {
			openOverlay(card);
		});
	});

	closeBtn.addEventListener('click', closeOverlay);

	overlay.addEventListener('click', function (e) {
		if (e.target === overlay || e.target.classList.contains('shay-overlay-inner')) {
			closeOverlay();
		}
	});

	document.addEventListener('keydown', function (e) {
		if (e.key === 'Escape') closeOverlay();
	});
});
</script>
</BaseLayout>
