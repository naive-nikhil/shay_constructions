<style is:global>
/* ===== Team Grid (default state) ===== */
.shay-team-grid {
	display: grid;
	grid-template-columns: repeat(6, 1fr);
	gap: 30px;
}

/* Row 1: three equal cards; row 2: two cards centered (empty half-column each side) */
.shay-team-card:nth-child(1) {
	grid-column: 1 / 3;
}
.shay-team-card:nth-child(2) {
	grid-column: 3 / 5;
}
.shay-team-card:nth-child(3) {
	grid-column: 5 / 7;
}
.shay-team-card:nth-child(4) {
	grid-column: 2 / 4;
}
.shay-team-card:nth-child(5) {
	grid-column: 4 / 6;
}

.shay-team-card {
	background: #fff;
	border: 1px solid #E9EBEC;
	padding: 22px;
	cursor: pointer;
	position: relative;
	overflow: hidden;
	z-index: 1;
	transition: all 0.5s ease;
}

.shay-team-card:hover {
	border-color: #1c4274;
	margin-top: -30px;
	margin-bottom: 30px;
}

.shay-team-img {
	overflow: hidden;
	position: relative;
	width: 100%;
	aspect-ratio: 3 / 4;
	background: #f0f0f0;
}
.shay-team-img img {
	width: 100%;
	height: 100%;
	object-fit: cover;
	object-position: top;
	display: block;
	transition: transform 0.5s ease;
}

.shay-team-card:hover .shay-team-img img {
	transform: scale(1.05);
}

.shay-team-label {
	position: absolute;
	bottom: -50%;
	left: 0;
	right: 0;
	text-align: center;
	margin: 0 auto;
	width: 85%;
	background: rgba(0, 0, 0, 0.75);
	padding: 25px 15px;
	opacity: 0;
	transition: all 0.7s ease;
}

.shay-team-card:hover .shay-team-label {
	bottom: 30px;
	opacity: 1;
}

.shay-team-label h3 {
	font-size: 18px;
	line-height: 26px;
	color: #fff;
	text-transform: uppercase;
	font-weight: 600;
	margin: 0 0 5px;
}

.shay-team-label span {
	font-size: 13px;
	color: rgba(255,255,255,0.7);
	text-transform: uppercase;
	font-weight: 500;
}

/* ===== Full-screen overlay ===== */
.shay-overlay {
	position: fixed;
	inset: 0;
	z-index: 99999;
	background:
		radial-gradient(ellipse at 20% 50%, rgba(28, 66, 116, 0.15) 0%, transparent 60%),
		radial-gradient(ellipse at 80% 20%, rgba(28, 66, 116, 0.08) 0%, transparent 50%),
		linear-gradient(160deg, #0a0a0a 0%, #0d0d0d 30%, #111 60%, #0a0a0a 100%);
	backdrop-filter: blur(12px);
	-webkit-backdrop-filter: blur(12px);
	opacity: 0;
	visibility: hidden;
	transition: opacity 0.7s ease, visibility 0s 0.7s;
}

.shay-overlay.active {
	opacity: 1;
	visibility: visible;
	transition: opacity 0.7s ease, visibility 0s 0s;
}

/* --- Close button --- */
.shay-overlay-close {
	position: absolute;
	top: 30px;
	right: 40px;
	z-index: 10;
	width: 50px;
	height: 50px;
	display: flex;
	align-items: center;
	justify-content: center;
	background: transparent;
	border: 1px solid rgba(255,255,255,0.2);
	color: rgba(255,255,255,0.6);
	font-size: 20px;
	cursor: pointer;
	transition: all 0.3s ease;
	opacity: 0;
	transform: rotate(-90deg);
}

.shay-overlay.active .shay-overlay-close {
	opacity: 1;
	transform: rotate(0deg);
	transition-delay: 0.5s;
}

.shay-overlay-close:hover {
	background: #1c4274;
	border-color: #1c4274;
	color: #fff;
	transform: rotate(90deg);
}

.shay-overlay-inner {
	display: flex;
	align-items: center;
	width: 100%;
	height: 100%;
	max-width: 1400px;
	margin: 0 auto;
	padding: 60px;
	gap: 80px;
}

/* --- Left: Image --- */
.shay-overlay-img {
	width: 45%;
	flex-shrink: 0;
	overflow: hidden;
	transform: translateX(-60px) scale(0.9);
	opacity: 0;
	transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1) 0.15s;
}

.shay-overlay.active .shay-overlay-img {
	transform: translateX(0) scale(1);
	opacity: 1;
}

.shay-overlay-img img {
	width: 100%;
	max-width: min(70vh, 520px);
	aspect-ratio: 3 / 4;
	height: auto;
	object-fit: cover;
	object-position: top;
	display: block;
	border: 3px solid rgba(28, 66, 116, 0.6);
}

/* --- Right: Info (white text, no background) --- */
.shay-overlay-info {
	flex: 1;
	transform: translateX(50px);
	opacity: 0;
	transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1) 0.35s;
}

.shay-overlay.active .shay-overlay-info {
	transform: translateX(0);
	opacity: 1;
}

.shay-overlay-role {
	font-size: 13px;
	color: #1c4274;
	text-transform: uppercase;
	font-weight: 600;
	letter-spacing: 3px;
	display: block;
	margin-bottom: 12px;
}

.shay-overlay-info h2 {
	font-size: 42px;
	color: #fff;
	text-transform: uppercase;
	font-weight: 700;
	margin: 0 0 20px;
	line-height: 1.1;
}

.shay-overlay-line {
	width: 60px;
	height: 3px;
	background: #1c4274;
	margin-bottom: 30px;
}

.shay-overlay-info p {
	font-size: 16px;
	line-height: 1.85;
	color: rgba(255, 255, 255, 0.7);
	margin: 0 0 35px;
	font-weight: 400;
	max-width: 520px;
}

.shay-overlay-social a {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	width: 46px;
	height: 46px;
	border: 1px solid rgba(255,255,255,0.2);
	color: #fff;
	margin-right: 12px;
	font-size: 16px;
