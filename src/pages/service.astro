---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Our Services - Shay Construction">

	<div class="breadcumb-area d-flex align-items-center">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					<div class="breadcumb-content">
						<h1>Our Services</h1>
						<ul>
							<li><a href="/">Home</a></li>
							<li>Our Services</li>
						</ul>
					</div>
				</div>
			</div>
		</div>
	</div>

	<section class="shay-about-hero">
		<div class="container">
			<div class="row align-items-center">
				<div class="col-lg-12">
					<div class="section-title upper">
						<div class="main-title">
							<h1>About Us</h1>
						</div>
						<div class="sub-title">
							<h2>Building Excellence with <span>Precision</span></h2>
						</div>
					</div>
				</div>
			</div>
			<div class="row align-items-center">
				<div class="col-lg-7">
					<div class="shay-about-hero-left wow fadeInLeft">
						<p>At SHAY Construction Pvt. Ltd., we prioritize quality and sustainability in every project. With a rapidly growing customer base, we specialize in premium construction and design. Our meticulous attention to detail sets us apart, while our diverse engineering team ensures excellence in every endeavor.</p>
						<p>From independent villas to multi-story buildings, we deliver exceptional results, supplemented by project management consultancy services to optimize efficiency for our clients.</p>
						<div class="shay-about-hero-check">
							<i class="bi bi-check-lg"></i> End-to-end: planning, design, execution, delivery &amp; consultancy
						</div>
					</div>
				</div>
				<div class="col-lg-5">
					<div class="shay-about-hero-right wow fadeInRight">
						<div class="shay-about-hero-card">
							<span class="shay-about-hero-card-label">OUR CORE PHILOSOPHY</span>
							<div class="shay-about-hero-stat wow fadeInUp" data-wow-delay="0.1s">
								<h3>Our Mission</h3>
								<p>To provide sustainable engineering solutions that prioritize longevity and resource sustainability — exceeding customer expectations at every stage.</p>
							</div>
							<div class="shay-about-hero-stat wow fadeInUp" data-wow-delay="0.3s">
								<h3>Our Vision</h3>
								<p>To be a leader in the construction industry by adhering to Precision in Quality and leveraging cutting-edge engineering resources.</p>
							</div>
							<div class="shay-about-hero-stat wow fadeInUp" data-wow-delay="0.5s">
								<h3>Our Values</h3>
								<p>Quality, sustainability, and customer satisfaction through precision engineering in all our endeavors.</p>
							</div>
						</div>
					</div>
				</div>
			</div>
			<div class="shay-hero-shape1 bounce-animate2">
				<img src="/assets/images/resource/counter-shape.png" alt="">
			</div>
			<div class="shay-hero-shape2 dance">
				<img src="/assets/images/resource/border.png" alt="">
			</div>
			<div class="shay-hero-shape3 bounce-animate3">
				<img src="/assets/images/resource/counter-shap.png" alt="">
			</div>
		</div>
	</section>

	<section class="shay-services-section">
		<div class="container">
			<div class="row align-items-center">
				<div class="col-lg-12">
					<div class="section-title upper">
						<div class="main-title">
							<h1>Services</h1>
						</div>
						<div class="sub-title">
							<h2>What We <span>Offer</span></h2>
						</div>
					</div>
					<div class="shay-svc-shape1 bounce-animate3">
						<img src="/assets/images/resource/counter-shape.png" alt="">
					</div>
					<div class="shay-svc-shape2 bounce-animate2">
						<img src="/assets/images/resource/counter-shap.png" alt="">
					</div>
				</div>
			</div>
			<div class="shay-services-grid">
				<div class="shay-service-card wow fadeInLeft" data-wow-delay="0.1s">
					<span class="shay-service-num">01</span>
					<h3>Residential Construction</h3>
					<p>We craft dream homes ranging from luxury independent villas to high-end row houses and residential apartments — with uncompromising quality and meticulous attention to detail.</p>
					<span class="shay-service-tag">Samsara Villas &bull; Media Enclave</span>
				</div>
				<div class="shay-service-card wow fadeInUp" data-wow-delay="0.2s">
					<span class="shay-service-num">02</span>
					<h3>Commercial Development</h3>
					<p>We deliver innovative spaces that inspire productivity, including contemporary offices, sales centers, and large-scale commercial districts with underground utilities.</p>
					<span class="shay-service-tag">DRI Commercial &bull; Jashn Elevate</span>
				</div>
				<div class="shay-service-card wow fadeInRight" data-wow-delay="0.3s">
					<span class="shay-service-num">03</span>
					<h3>Infrastructure & Landscape</h3>
					<p>We build the backbone of communities by developing resilient public infrastructure and large-scale landscapes — over 65.3 acres delivered for prestigious global clients.</p>
					<span class="shay-service-tag">1 OAK-NATURA &bull; Samsara Homes</span>
				</div>
				<div class="shay-service-card wow fadeInLeft" data-wow-delay="0.1s">
					<span class="shay-service-num">04</span>
					<h3>Institutional & University</h3>
					<p>We create campuses designed to foster learning, collaboration, and institutional growth — strictly adhering to government standards and delivered on tight timelines.</p>
					<span class="shay-service-tag">ABVMU &bull; Dr. RML Academy</span>
				</div>
				<div class="shay-service-card wow fadeInUp" data-wow-delay="0.2s">
					<span class="shay-service-num">05</span>
					<h3>Towers & High Rises</h3>
					<p>Our engineering team specializes in iconic multi-story structures up to G+9 that redefine urban skylines, utilizing advanced assets for structural precision from foundation up.</p>
					<span class="shay-service-tag">Mahila Battalion &bull; Sushant Golf City</span>
				</div>
				<div class="shay-service-card wow fadeInRight" data-wow-delay="0.3s">
					<span class="shay-service-num">06</span>
					<h3>Government & Healthcare</h3>
					<p>We partner with public authorities to deliver impactful infrastructure including specialized hospital projects — all following strict OHES policy compliance.</p>
					<span class="shay-service-tag">600-bed Command Hospital &bull; PWD Guest House</span>
				</div>
			</div>
		</div>
	</section>

	<!--==================================================-->
	<!-- Start counter area -->
	<!--==================================================-->

	<div class="counter-area one upper">
		<div class="container">
			<div class="row bg-col align-items-center">
				<div class="col-lg-3 col-md-6">
					<div class="counter-single-item-inner wow fadeInUp">
						<div class="counter-content">
							<div class="counter-text">
								<h1><span class="counter">45</span>+</h1>
								<span></span>
								<div class="counter-title">
									<h4>ALL WORKS</h4>
								</div>
							</div>
						</div>
					</div>
				</div>
				<div class="col-lg-3 col-md-6">
					<div class="counter-single-item-inner upper">
						<div class="counter-content">
							<div class="counter-text">
								<h1><span class="counter">65</span>+</h1>
								<span></span>
								<div class="counter-title">
									<h4>ENGINEERS</h4>
								</div>
							</div>
						</div>
					</div>
				</div>
				<div class="col-lg-3 col-md-6">
					<div class="counter-single-item-inner wow fadeInUp">
						<div class="counter-content">
							<div class="counter-text">
								<h1><span class="counter">600</span>+</h1>
								<span></span>
								<div class="counter-title">
									<h4>TOTAL TEAM</h4>
								</div>
							</div>
						</div>
					</div>
				</div>
				<div class="col-lg-3 col-md-6">
					<div class="counter-single-item-inner upper">
						<div class="counter-content">
							<div class="counter-text">
								<h1><span class="counter">1.2</span>M+</h1>
								<span></span>
								<div class="counter-title">
									<h4>AREA CREATED</h4>
								</div>
							</div>
						</div>
					</div>
				</div>
				<div class="conun-shap bounce-animate3">
					<img src="/assets/images/resource/counter-shape.png" alt="">
				</div>
				<div class="conunt-shape bounce-animate2">
					<img src="/assets/images/resource/counter-shap.png" alt="">
				</div>
			</div>
		</div>	
	</div>

	<!--==================================================-->
	<!-- End counter area -->
	<!--==================================================-->


	<!--==================================================-->
	<!-- Start brand-area -->
	<!--==================================================-->

	<div class="brand-area one upper">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					<div class="brand-title">
						<h4><span>40+</span> Satisfied Customers</h4>
					</div>
				</div>
			</div>
			<div class="row">
				<div class="owl-carousel brand_list">
					<div class="col-lg-12">
						<div class="single-brand wow fadeInRight">
							<div class="brand-thumb">
								<img src="https://www.jkumar.com/jkumar_logo_white.png" alt="">
							</div>
						</div>
					</div>
					<div class="col-lg-12">
						<div class="single-brand wow fadeInLeft">
							<div class="brand-thumb">
								<img src="https://cdn.jashnrealty.com/assets/v2/images/logo-blue.png" alt="">
							</div>
						</div>
					</div>
					<div class="col-lg-12">
						<div class="single-brand wow fadeInRight">
							<div class="brand-thumb">
								<img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQTZAlWtXRVdmUCXsD0jAWcA60VVqaDQInPbQ&s" alt="">
							</div>
						</div>
					</div>
					<div class="col-lg-12">
						<div class="single-brand wow fadeInLeft">
							<div class="brand-thumb">
								<img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcS8smN38yurYrpWmNvwdZE4_t6MAO0SDZoyHQ&s" alt="">
							</div>
						</div>
					</div>
					<div class="col-lg-12">
						<div class="single-brand wow fadeInRight">
							<div class="brand-thumb">
								<img src="https://omaxe-lucknow.com/wp-content/uploads/2022/12/Omaxe-logo.png" alt="">
							</div>
						</div>
					</div>
					<div class="col-lg-12">
						<div class="single-brand wow fadeInRight">
							<div class="brand-thumb">
								<img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSbg49dq8Ev_HEeQLgR67IqUZWU7wDhiktaJg&s" alt="">
							</div>
						</div>
					</div>
					<div class="col-lg-12">
						<div class="single-brand wow fadeInRight">
							<div class="brand-thumb">
								<img src="https://uniqueinfra.in/images/unique-infra-engg-logo.png" alt="">
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!--==================================================-->
	<!-- End brand-area -->
	<!--==================================================-->

<style is:global>
/* About hero section */
.shay-about-hero {
	padding: 100px 0 80px;
	background: #FAFAFA;
	position: relative;
	overflow: hidden;
}

.shay-about-hero .container {
	position: relative;
}

.shay-about-hero-left {
	padding-right: 50px;
}

.shay-about-hero-left p {
	font-size: 15px;
	line-height: 1.8;
	color: #555;
	margin: 0 0 16px;
}

.shay-about-hero-check {
	margin-top: 28px;
	font-size: 13px;
	color: #888;
	display: flex;
	align-items: center;
	gap: 8px;
}

.shay-about-hero-check i {
	color: #1c4274;
	font-size: 16px;
	font-weight: 700;
}

/* Right card */
.shay-about-hero-right {
	padding-left: 20px;
}

.shay-about-hero-card {
	background: #fff;
	border: 1px solid #E9EBEC;
	padding: 40px 35px;
	position: relative;
	z-index: 1;
}

.shay-about-hero-card-label {
	display: block;
	font-size: 12px;
	font-weight: 700;
	letter-spacing: 3px;
	color: #1c4274;
	text-transform: uppercase;
	margin-bottom: 30px;
	padding-bottom: 20px;
	border-bottom: 1px solid #E9EBEC;
}

.shay-about-hero-stat {
	margin-bottom: 28px;
}

.shay-about-hero-stat:last-child {
	margin-bottom: 0;
}

.shay-about-hero-stat h3 {
	font-size: 18px;
	font-weight: 700;
	color: #1c4274;
	margin: 0 0 8px;
}

.shay-about-hero-stat p {
	font-size: 14px;
	line-height: 1.7;
	color: #666;
	margin: 0;
}

/* Floating decorative shapes for about hero */
.shay-hero-shape1 {
	position: absolute;
	top: 30px;
	right: 80px;
	z-index: 0;
	opacity: 0.12;
}

.shay-hero-shape2 {
	position: absolute;
	bottom: 40px;
	left: 20px;
	z-index: 0;
	opacity: 0.10;
}

.shay-hero-shape3 {
	position: absolute;
	top: 50%;
	left: 45%;
	z-index: 0;
	opacity: 0.08;
}

@media (max-width: 991px) {
	.shay-about-hero-left {
		padding-right: 0;
		margin-bottom: 40px;
	}
	.shay-about-hero-right {
		padding-left: 0;
	}
	.shay-hero-shape1,
	.shay-hero-shape2,
	.shay-hero-shape3 {
		display: none;
	}
}

@media (max-width: 575px) {
	.shay-about-hero {
		padding: 70px 0 60px;
	}
}

/* Services grid */
.shay-services-section {
	padding: 100px 0 120px;
	background: #fff;
	position: relative;
	overflow: hidden;
}

/* Floating shapes for services section */
.shay-svc-shape1 {
	position: absolute;
	top: 20px;
	right: -30px;
	z-index: 0;
	opacity: 0.10;
}

.shay-svc-shape2 {
	position: absolute;
	bottom: -20px;
	left: -40px;
	z-index: 0;
	opacity: 0.08;
}

.shay-services-grid {
	display: grid;
	grid-template-columns: repeat(3, 1fr);
	position: relative;
	z-index: 1;
}

.shay-service-card {
	padding: 45px 35px;
	border: 1px solid #E9EBEC;
	margin-top: -1px;
	margin-left: -1px;
	position: relative;
	transition: all 0.4s ease;
}

.shay-service-card:hover {
	background: #FAFAFA;
}

.shay-service-num {
	display: block;
	font-size: 14px;
	font-weight: 600;
	color: #1c4274;
	margin-bottom: 28px;
	letter-spacing: 1px;
}

.shay-service-card h3 {
	font-size: 22px;
	font-weight: 700;
	color: #101010;
	line-height: 1.3;
	margin: 0 0 18px;
	text-transform: none;
}

.shay-service-card p {
	font-size: 14px;
	line-height: 1.75;
	color: #666;
	margin: 0 0 20px;
	font-weight: 400;
}

.shay-service-tag {
	display: block;
	font-size: 12px;
	color: #999;
	font-weight: 500;
	letter-spacing: 0.5px;
	font-style: italic;
}

/* Hover accent line */
.shay-service-card::after {
	content: "";
	position: absolute;
	bottom: 0;
	left: 0;
	width: 0;
	height: 3px;
	background: #1c4274;
	transition: width 0.4s ease;
}

.shay-service-card:hover::after {
	width: 100%;
}

/* Responsive */
@media (max-width: 991px) {
	.shay-services-grid {
		grid-template-columns: repeat(2, 1fr);
	}
	.shay-service-card {
		padding: 35px 28px;
	}
	.shay-svc-shape1,
	.shay-svc-shape2 {
		display: none;
	}
}

@media (max-width: 575px) {
	.shay-services-grid {
		grid-template-columns: 1fr;
	}
	.shay-services-section {
		padding: 70px 0 80px;
	}
}
</style>

</BaseLayout>
